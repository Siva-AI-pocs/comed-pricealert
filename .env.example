DATABASE_URL=sqlite:///./data/comed.db
POLL_INTERVAL_SECONDS=300
HISTORY_DAYS=7

# Telegram (optional) — get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# WhatsApp via Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Email / SMTP (optional) — use Gmail App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_FROM_ADDRESS=

# Alert cooldown: minimum minutes between alerts per subscriber
ALERT_COOLDOWN_MINUTES=60

APP_HOST=0.0.0.0
APP_PORT=8000
